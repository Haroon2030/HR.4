# انسخ هذا الملف إلى config.env (لا ترفع config.env إلى Git)
# احفظ بـ UTF-8 بدون BOM، أو استخدم: copy config.example.env config.env
#
# عنوان نظام HR على الإنترنت (بدون / في النهاية)
SERVER_URL=http://72.61.107.230:8082

# نفس المفتاح في .env السيرفر: ATTENDANCE_AGENT_API_KEY
# أنشئه: python manage.py generate_attendance_agent_key
AGENT_API_KEY=ضع_المفتاح_هنا

# معرّف الجهاز في النظام (من /attendance/devices/)
DEVICE_ID=1

# جهاز البصمة على شبكة الفرع
DEVICE_IP=192.168.51.3
DEVICE_PORT=4370
COMM_KEY=0

# اسم الوكيل (للتتبع)
AGENT_ID=sky-mall-branch

# كل كم ثانية يُعاد السحب (300 = 5 دقائق)
POLL_INTERVAL_SEC=300
TIMEOUT_SEC=20

# true = يرسل الجديد فقط (موصى به)
INCREMENTAL=true
