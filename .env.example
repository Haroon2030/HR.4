# ─── Django ───────────────────────────────────────────────────────────────────
DJANGO_ENV=production
DJANGO_SETTINGS_MODULE=config.settings
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False

# Hosts allowed to serve the app (comma-separated)
ALLOWED_HOSTS=72.61.107.230,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://72.61.107.230,http://72.61.107.230:8082

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
# Production uses Neon (managed Postgres). Get URL from https://console.neon.tech
# Format: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
# IMPORTANT: '@' inside the password must be url-encoded as %40
#
# Production (Neon pooler — required for Dokploy, supports many connections):
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-small-brook-api71buq-pooler.c-7.us-east-1.aws.neon.tech/hr?sslmode=require
#
# Local Postgres alternative (if running your own):
# DATABASE_URL=postgres://hr_user:Haro%4012345678@hr-hrdba-zkqglc:5432/hr_db
#
# SQLite for offline local dev (uncomment to use, comment out the above):
# DATABASE_URL=sqlite:///db.sqlite3

# SSL mode for external managed Postgres (Neon, Supabase, RDS). Use 'disable' for local.
DB_SSLMODE=require

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://72.61.107.230,http://72.61.107.230:8082

# ─── Security (enable when you put the app behind HTTPS) ──────────────────────
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
